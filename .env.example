# ---------------------------------------------------------------------------
# Thouqi Platform — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# NEVER commit `.env.local`. The service-role key must never be exposed client-side.
# ---------------------------------------------------------------------------

# --- Supabase (backend) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Publishable (anon) key — safe for the browser, protected by Row Level Security.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Service-role key — SERVER ONLY. Bypasses RLS. Used by admin/service layer.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Site ---
# Canonical URL used for SEO, sitemaps, hreflang, Open Graph.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Optional: extra image CDN hostnames (comma separated) ---
NEXT_PUBLIC_IMAGE_HOSTS=

# --- Optional: Firebase (analytics only) ---
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Feature flags default source: `local` (config file) or `remote` (Supabase) ---
NEXT_PUBLIC_CONFIG_SOURCE=local
